---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schema?: string;
}

const { title, description, canonicalUrl, schema } = Astro.props;
const currentUrl = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0QHJXP79WY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-0QHJXP79WY');
    </script>
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph (Facebook / WhatsApp) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://autosocorroexcelencia.com.br/images/share.jpg" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://autosocorroexcelencia.com.br/images/share.jpg" />

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Schema.org Structured Data -->
    {schema && <script type="application/ld+json" set:html={schema} />}
    
    <!-- Local Business Schema por Padrão -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AutoTowing",
        "name": "Auto Socorro Excelência",
        "image": "https://autosocorroexcelencia.com.br/images/logo.png",
        "@id": "https://autosocorroexcelencia.com.br/#localbusiness",
        "url": "https://autosocorroexcelencia.com.br",
        "telephone": "+5562985869296",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. Marechal Rondon, Qd. C, Lt. 20",
          "addressLocality": "Residencial Morumbi",
          "addressRegion": "Goiânia - GO",
          "postalCode": "74565-170",
          "addressCountry": "BR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -16.6385,
          "longitude": -49.2789
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "00:00",
          "closes": "23:59"
        },
        "areaServed": [
          {
            "@type": "AdministrativeArea",
            "name": "Goiânia"
          },
          {
            "@type": "AdministrativeArea",
            "name": "Aparecida de Goiânia"
          }
        ]
      }
    </script>
  </head>
  <body>
    <!-- Top Bar Emergency -->
    <div class="top-bar">
      <div class="container top-bar-content">
        <span class="emergency-badge"><span class="pulse"></span> ATENDIMENTO DE EMERGÊNCIA 24 HORAS</span>
        <div class="top-bar-contacts">
          <a href="tel:+5562985869296" class="top-contact-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            (62) 98586-9296
          </a>
          <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Vim%20pelo%20site%20e%20preciso%20de%20um%20guincho." target="_blank" rel="noopener noreferrer" class="top-contact-link top-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Header Navigation -->
    <header class="main-header">
      <div class="container header-container">
        <a href="/" class="logo-link">
          <img src="/images/logo.png" alt="Auto Socorro Excelência Logo" class="header-logo" width="160" height="42" />
        </a>
        
        <button class="mobile-menu-toggle" id="mobile-toggle" aria-label="Abrir Menu">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>

        <nav class="nav-menu" id="nav-menu">
          <a href="/#servicos" class="nav-link">Serviços</a>
          <a href="/#bairros" class="nav-link">Bairros Atendidos</a>
          <a href="/#sobre" class="nav-link">Quem Somos</a>
          <a href="/#faq" class="nav-link">Dúvidas Comuns</a>
          <div class="nav-cta-group">
            <a href="tel:+5562985869296" class="btn-tel-call">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              LIGAR AGORA
            </a>
            <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Vim%20pelo%20site%20e%20preciso%20de%20um%20guincho." target="_blank" rel="noopener noreferrer" class="btn-wa-call">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              WHATSAPP
            </a>
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content Area -->
    <main>
      <slot />
    </main>

    <!-- Footer Section -->
    <footer class="main-footer">
      <div class="container footer-grid">
        <div class="footer-col-about">
          <img src="/images/logo.png" alt="Auto Socorro Excelência Logo" class="footer-logo" width="160" height="42" />
          <p class="footer-about-text">
            O <strong>Auto Socorro Excelência</strong> é sinônimo de rapidez, confiança e atendimento humanizado. Com frota própria de guinchos plataforma modernos, estamos prontos para remover seu carro, moto ou caminhonete leve 24 horas por dia em qualquer ponto de Goiânia e Aparecida de Goiânia.
          </p>
          <div class="footer-emergency">
            <span class="emerg-txt">Emergência 24H:</span>
            <a href="tel:+5562985869296" class="emerg-phone">(62) 98586-9296</a>
          </div>
        </div>
        
        <div class="footer-col-links">
          <h3>Serviços Reboque</h3>
          <ul>
            <li><a href="/#servicos">Guincho para Carros</a></li>
            <li><a href="/#servicos">Guincho para Motos</a></li>
            <li><a href="/#servicos">Reboque de Caminhonetes</a></li>
            <li><a href="/#servicos">Auxílio Pane Elétrica/Mecânica</a></li>
            <li><a href="/#servicos">Recarga de Bateria (Chupeta)</a></li>
          </ul>
        </div>
        
        <div class="footer-col-contact">
          <h3>Nossa Localização</h3>
          <p class="footer-contact-item">
            <strong>Base Operacional:</strong><br />
            Av. Marechal Rondon, Qd. C, Lt. 20<br />
            Residencial Morumbi<br />
            Goiânia - GO
          </p>
          <p class="footer-contact-item">
            <strong>Contatos Rápidos:</strong><br />
            WhatsApp/Ligações: <a href="tel:+5562985869296">(62) 98586-9296</a><br />
            Telefone Auxiliar: <a href="tel:+5562992557840">(62) 99255-7840</a> <span style="font-size: 0.85em; opacity: 0.8; color: var(--yellow);">(Apenas Ligações)</span>
          </p>
        </div>
      </div>
      
      <!-- Footer Bottom -->
      <div class="footer-bottom">
        <div class="container footer-bottom-content">
          <p>&copy; {new Date().getFullYear()} Auto Socorro Excelência. Todos os direitos reservados. Goiânia - GO.</p>
          <div class="footer-seo-links">
            <a href="/robots.txt">robots.txt</a> | <a href="/sitemap.xml">sitemap.xml</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Persistent Floating WhatsApp Button -->
    <a 
      href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Vim%20pelo%20site%20e%20preciso%20de%20um%20guincho." 
      target="_blank" 
      rel="noopener noreferrer" 
      class="whatsapp-floating-button"
      aria-label="Falar no WhatsApp com Auto Socorro Excelência"
    >
      <svg class="wa-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
      </svg>
      <span class="wa-tooltip">Chamar Guincho 24h</span>
    </a>

    <!-- Hamburger menu control -->
    <script>
      const mobileToggle = document.getElementById('mobile-toggle');
      const navMenu = document.getElementById('nav-menu');
      
      if (mobileToggle && navMenu) {
        mobileToggle.addEventListener('click', () => {
          mobileToggle.classList.toggle('active');
          navMenu.classList.toggle('active');
        });

        // Fechar menu ao clicar em links
        const navLinks = navMenu.querySelectorAll('a');
        navLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileToggle.classList.remove('active');
            navMenu.classList.remove('active');
          });
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* Global Design Tokens & Variables */
  :root {
    --primary: #ffca00; /* Amarelo aviso/alerta vibrante */
    --primary-dark: #070b13; /* Fundo escuro midnight */
    --primary-light: rgba(0, 229, 255, 0.06); /* Ciano transparente para fundos de destaque */
    --accent: #00e5ff; /* Azul Elétrico / Ciano Neon do Logo */
    --accent-hover: #00b0ff; /* Azul royal de hover */
    --danger: #ff3366; /* Vermelho rubi para emergência */
    --dark: #090d16; /* Fundo base escuro */
    --gray-dark: #94a3b8; /* Cinza claro para textos de leitura */
    --gray-light: #162032; /* Fundo de cartões secundários */
    --white: #ffffff;
    
    --font-heading: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    
    --max-width: 1200px;
    --header-height: 80px;
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.5);
    --shadow-md: 0 8px 30px rgba(0, 229, 255, 0.06);
    --shadow-lg: 0 12px 40px rgba(0, 229, 255, 0.12);
    --neon-glow: 0 0 20px rgba(0, 229, 255, 0.25), 0 0 40px rgba(0, 229, 255, 0.1);
    
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 24px;
  }

  /* Base Reset */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-body);
    color: #e2e8f0;
    background-color: var(--dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  section {
    padding: 80px 0;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 50px;
  }

  .section-header h2 {
    font-size: 1.7rem; /* Reduzido para maior elegância e equilíbrio */
    margin-bottom: 15px;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    color: var(--white);
  }

  .section-header p {
    font-size: 1.1rem;
    color: var(--gray-dark);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-weight: 700;
    padding: 14px 28px;
    border-radius: var(--radius-md);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background-color: var(--primary);
    color: var(--primary-dark);
    box-shadow: 0 4px 14px rgba(255, 199, 0, 0.3);
  }

  .btn-primary:hover {
    background-color: var(--primary-dark);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(10, 18, 44, 0.4);
  }

  .btn-wa {
    background-color: var(--accent);
    color: var(--white);
    box-shadow: 0 4px 14px rgba(34, 197, 94, 0.3);
  }

  .btn-wa:hover {
    background-color: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(34, 197, 94, 0.4);
  }

  .btn-tel {
    background-color: var(--danger);
    color: var(--white);
    box-shadow: 0 4px 14px rgba(220, 38, 38, 0.3);
  }

  .btn-tel:hover {
    background-color: #b91c1c;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
  }

  /* Header & Navigation Styles */
  .top-bar {
    background-color: var(--primary-dark);
    color: var(--white);
    font-size: 0.85rem;
    padding: 8px 0;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .top-bar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .emergency-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #fca5a5;
  }

  .pulse {
    display: inline-block;
    width: 8px;
    height: 8px;
    background-color: #ef4444;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    animation: pulse-ring 1.5s infinite;
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 6px rgba(239, 68, 68, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
    }
  }

  .top-bar-contacts {
    display: flex;
    gap: 15px;
  }

  .top-contact-link {
    display: flex;
    align-items: center;
    gap: 5px;
    opacity: 0.9;
  }

  .top-contact-link:hover {
    opacity: 1;
    color: var(--accent);
  }

  .top-whatsapp {
    color: var(--accent);
  }

  .main-header {
    background-color: var(--primary-dark);
    border-bottom: 1px solid rgba(0, 229, 255, 0.15);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    display: flex;
    align-items: center;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .header-logo {
    max-height: 48px;
    width: auto;
    object-fit: contain;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-link {
    font-weight: 600;
    color: #cbd5e1;
    font-size: 0.95rem;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-cta-group {
    display: flex;
    gap: 10px;
    margin-left: 10px;
  }

  .btn-tel-call, .btn-wa-call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 10px 16px;
    border-radius: var(--radius-sm);
    color: var(--white);
    letter-spacing: 0.5px;
  }

  .btn-tel-call {
    background-color: var(--danger);
  }

  .btn-tel-call:hover {
    background-color: #b91c1c;
    transform: translateY(-1px);
  }

  .btn-wa-call {
    background-color: var(--accent);
  }

  .btn-wa-call:hover {
    background-color: var(--accent-hover);
    transform: translateY(-1px);
  }

  /* Hamburger Menu */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 26px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .mobile-menu-toggle .bar {
    width: 100%;
    height: 3px;
    background-color: var(--primary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Footer Styles */
  .main-footer {
    background-color: #05080f;
    color: #e2e8f0;
    padding: 60px 0 0;
    font-size: 0.95rem;
    border-top: 1px solid rgba(0, 229, 255, 0.15);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 50px;
    border-bottom: 1px solid rgba(0, 229, 255, 0.15);
  }

  .footer-logo {
    max-height: 55px;
    margin-bottom: 20px;
  }

  .footer-about-text {
    color: #94a3b8;
    margin-bottom: 25px;
    font-size: 0.9rem;
    max-width: 480px;
  }

  .footer-emergency {
    background: rgba(255, 255, 255, 0.03);
    border-left: 4px solid var(--danger);
    padding: 12px 20px;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    display: inline-block;
  }

  .footer-emergency .emerg-txt {
    font-size: 0.8rem;
    color: #f87171;
    font-weight: 700;
    display: block;
    text-transform: uppercase;
  }

  .footer-emergency .emerg-phone {
    font-size: 1.6rem;
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--white);
  }

  .footer-col-links h3, .footer-col-contact h3 {
    color: var(--white);
    font-size: 1.2rem;
    margin-bottom: 20px;
    position: relative;
    padding-bottom: 8px;
  }

  .footer-col-links h3::after, .footer-col-contact h3::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background-color: var(--accent);
  }

  .footer-col-links ul {
    list-style: none;
  }

  .footer-col-links ul li {
    margin-bottom: 12px;
  }

  .footer-col-links ul li a {
    color: #94a3b8;
  }

  .footer-col-links ul li a:hover {
    color: var(--accent);
    padding-left: 5px;
  }

  .footer-contact-item {
    margin-bottom: 20px;
    color: #94a3b8;
    font-size: 0.9rem;
  }

  .footer-contact-item strong {
    color: var(--white);
  }

  .footer-contact-item a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    background-color: #020408;
    padding: 20px 0;
    font-size: 0.85rem;
    color: #64748b;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
