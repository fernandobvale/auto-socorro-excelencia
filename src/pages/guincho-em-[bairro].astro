---
import Layout from '../layouts/Layout.astro';
import { bairros } from '../data/bairros.js';
import { Image } from 'astro:assets';
import bannerImg from '../assets/images/banner.webp';
import serviceCarImg from '../assets/images/service_car.webp';
import servicePickupAltImg from '../assets/images/service_pickup_alt.webp';
import serviceMotoImg from '../assets/images/service_moto.webp';

export async function getStaticPaths() {
  return bairros.map((b) => ({
    params: { bairro: b.slug },
    props: { bairroData: b },
  }));
}

const { bairro } = Astro.params;
const { bairroData } = Astro.props;

// Localized pre-filled WhatsApp link text
const waMessage = encodeURIComponent(`Olá! Preciso de um guincho na região do ${bairroData.name} em ${bairroData.city}.`);
const waUrl = `https://api.whatsapp.com/send?phone=5562985869296&text=${waMessage}`;

// Local Business Schema specialized for the neighborhood
const neighborhoodSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AutoTowing",
  "name": `Auto Socorro Excelência - Guincho no ${bairroData.name}`,
  "image": "https://autosocorroexcelencia.com.br/images/logo.png",
  "url": `https://autosocorroexcelencia.com.br/guincho-em-${bairroData.slug}`,
  "telephone": "+5562985869296",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Marechal Rondon, Qd. C, Lt. 20",
    "addressLocality": "Residencial Morumbi",
    "addressRegion": "Goiânia - GO",
    "postalCode": "74565-170",
    "addressCountry": "BR"
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": `${bairroData.name}, ${bairroData.city}`
  }
});
---

<Layout 
  title={bairroData.metaTitle} 
  description={bairroData.metaDescription}
  schema={neighborhoodSchema}
>
  <!-- Breadcrumbs & Local Header -->
  <div class="breadcrumb-bar">
    <div class="container breadcrumbs">
      <a href="/">Home</a>
      <span class="separator">/</span>
      <a href="/#bairros">Áreas de Atendimento</a>
      <span class="separator">/</span>
      <span class="current">Guincho no {bairroData.name}</span>
    </div>
  </div>

  <!-- Localized Hero Section -->
  <section class="local-hero">
    <div class="container local-hero-grid">
      <div class="local-hero-text">
        <span class="local-badge">🚨 Guincho Plataforma 24H</span>
        <h1>Guincho e Auto Socorro no {bairroData.name}</h1>
        <p class="local-lead">
          Teve um imprevisto na região do <strong>{bairroData.name}</strong> em {bairroData.city}? O <strong>Auto Socorro Excelência</strong> é a sua melhor opção para reboque de carros, motos e picapes com rapidez extrema e preço justo!
        </p>
        
        <div class="local-hero-ctas">
          <a href="tel:+5562985869296" class="btn btn-tel local-tel-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            LIGAR 24H: (62) 98586-9296
          </a>
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn btn-wa">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            PEDIR GUINCHO NO WHATSAPP
          </a>
        </div>
      </div>

      <div class="local-hero-visual">
        <div class="local-visual-card">
          <Image src={bannerImg} alt={`Auto Socorro Excelência servindo o ${bairroData.name}`} class="local-hero-img" width={576} height={324} loading="eager" />
          <div class="local-floating-tag">
            <span class="pulse"></span> <strong>Chegada Estimada:</strong> 20 a 30 min
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Localized SEO Article Section -->
  <section class="local-article">
    <div class="container article-grid">
      <div class="article-body">
        <h2>Atendimento de Emergência e Remoção 24h no {bairroData.name}</h2>
        <p>
          Seja para ir ao trabalho, voltar para casa ou durante uma viagem, imprevistos com o carro podem acontecer. Se você está no <strong>{bairroData.name}</strong> ou redondezas e precisa de assistência, conte com o <strong>Auto Socorro Excelência</strong>. Oferecemos reboque plataforma hidráulica moderno, ideal para a remoção segura de carros de passeio, motocicletas de todos os modelos e caminhonetes leves.
        </p>
        
        <h3>Equipe Preparada Para Todos os Cenários</h3>
        <p>
          Nossa equipe possui anos de experiência prática e conhece perfeitamente a malha urbana do <strong>{bairroData.name}</strong>. Realizamos resgates em:
        </p>
        <ul class="article-bullets">
          <li><strong>Pane Mecânica ou Elétrica:</strong> Caso seu automóvel pare de funcionar inesperadamente.</li>
          <li><strong>Pane Seca (Falta de Combustível):</strong> Apoio imediato para remoção até o posto de combustível mais próximo.</li>
          <li><strong>Recarga de Bateria (Chupeta):</strong> Solução rápida caso o veículo não dê partida por bateria descarregada.</li>
          <li><strong>Acidentes e Colisões:</strong> Remoção com todo o cuidado para oficinas credenciadas, concessionárias ou sua garagem.</li>
        </ul>

        <blockquote>
          <strong>Sabia disso?</strong> Nossa sede oficial fica no <em>Residencial Morumbi</em> em Goiânia. Devido a essa proximidade geográfica, conseguimos cruzar as principais vias expressas e avenidas de ligação para chegar até o <strong>{bairroData.name}</strong> em tempo recorde!
        </blockquote>

        <h3>Como Solicitar Nosso Guincho?</h3>
        <p>
          O processo é simples, transparente e sem burocracia:
        </p>
        <ol class="article-steps">
          <li><strong>Entre em contato:</strong> Clique em qualquer botão de ligação ou WhatsApp nesta página.</li>
          <li><strong>Informe a localização:</strong> Mande seu ponto exato no {bairroData.name} ou nos descreva um ponto de referência.</li>
          <li><strong>Receba o orçamento:</strong> Informamos o valor fechado na hora, de acordo com o trajeto, sem surpresas desagradáveis.</li>
          <li><strong>Aguarde no local:</strong> Nossa plataforma hidráulica se deslocará imediatamente até você.</li>
        </ol>
      </div>

      <div class="article-sidebar">
        <div class="sidebar-box contact-box">
          <h3>Fale Conosco Agora</h3>
          <p>Orçamento rápido via ligação telefônica ou WhatsApp. Atendimento humanizado e imediato.</p>
          <a href="tel:+5562985869296" class="sidebar-btn btn-tel">
            📞 (62) 98586-9296
          </a>
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="sidebar-btn btn-wa">
            💬 WhatsApp 24h
          </a>
          <p class="sidebar-aux-phone">Fixo/Apoio: <strong>(62) 98586-9296</strong></p>
        </div>

        <div class="sidebar-box info-box">
          <h3>Detalhes de Serviço</h3>
          <ul>
            <li><strong>Serviço:</strong> Guincho Plataforma Hidráulica</li>
            <li><strong>Veículos:</strong> Carros, Motos e Caminhonetes</li>
            <li><strong>Tempo de Chegada:</strong> 20 a 40 minutos</li>
            <li><strong>Funcionamento:</strong> 24h (Sáb, Dom e Feriados)</li>
            <li><strong>Pagamento:</strong> PIX, Débito, Crédito e Dinheiro</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Localized Fleet Gallery Section -->
  <section class="trust-fleet">
    <div class="container">
      <div class="section-header">
        <h2>Nossos Equipamentos e Serviços Reais</h2>
        <p>Garantimos excelência em cada reboque. Veja fotos reais do nosso trabalho e equipamentos atendendo na região de Goiânia.</p>
      </div>
      
      <div class="fleet-grid">
        <div class="fleet-card">
          <Image src={serviceCarImg} alt="Guincho de carro em plataforma" width={400} height={250} loading="lazy" />
          <div class="fleet-info">
            <h4>Carros de Passeio</h4>
            <p>Plataforma estável e segura para hatches e sedans.</p>
          </div>
        </div>
        <div class="fleet-card">
          <Image src={servicePickupAltImg} alt="Reboque de caminhonete leve" width={400} height={250} loading="lazy" />
          <div class="fleet-info">
            <h4>Caminhonetes e Picapes</h4>
            <p>Equipamento robusto para transporte seguro de veículos de médio porte.</p>
          </div>
        </div>
        <div class="fleet-card">
          <Image src={serviceMotoImg} alt="Transporte de motocicleta" width={600} height={450} loading="lazy" />
          <div class="fleet-info">
            <h4>Motos com Suporte Vertical</h4>
            <p>Segurança total com fixações projetadas para veículos de duas rodas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Outros Bairros Atendidos -->
  <section class="other-bairros">
    <div class="container">
      <div class="section-header">
        <h2>Outras Áreas com Atendimento 24h</h2>
        <p>Também atendemos rapidamente em outros setores e regiões de Goiânia e Aparecida:</p>
      </div>
      
      <div class="other-bairros-list">
        {bairros.filter(b => b.slug !== bairro).slice(0, 8).map(b => (
          <a href={`/guincho-em-${b.slug}`} class="other-bairro-link">
            Guincho no {b.name}
          </a>
        ))}
      </div>
      
      <div class="view-all-bairros-wrapper">
        <a href="/#bairros" class="btn btn-primary">Ver Todos os Bairros Atendidos</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Breadcrumbs */
  .breadcrumb-bar {
    background-color: #05080f;
    border-bottom: 1px solid rgba(0, 229, 255, 0.15);
    padding: 12px 0;
    font-size: 0.85rem;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #94a3b8;
    font-weight: 500;
  }

  .breadcrumbs a {
    color: #94a3b8;
  }

  .breadcrumbs a:hover {
    color: var(--accent);
  }

  .breadcrumbs .separator {
    color: #cbd5e1;
  }

  .breadcrumbs .current {
    color: var(--accent);
    font-weight: 700;
  }

  /* Local Hero */
  .local-hero {
    background: radial-gradient(circle at 80% 20%, #0c1524 0%, #05080e 100%);
    color: var(--white);
    padding: 70px 0 90px;
    position: relative;
    border-bottom: 1px solid rgba(0, 229, 255, 0.15);
  }

  .local-hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .local-badge {
    display: inline-block;
    background-color: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.25);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 50px;
    margin-bottom: 15px;
    text-transform: uppercase;
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.05);
  }

  .local-hero-text h1 {
    color: var(--white);
    font-size: 2.8rem;
    line-height: 1.2;
    margin-bottom: 15px;
    text-transform: uppercase;
  }

  .local-lead {
    font-size: 1.15rem;
    color: #cbd5e1;
    margin-bottom: 35px;
    line-height: 1.6;
  }

  .local-lead strong {
    color: var(--accent);
  }

  .local-hero-ctas {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .local-tel-btn {
    animation: local-pulse 2s infinite ease-in-out;
  }

  @keyframes local-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); box-shadow: 0 0 15px rgba(220, 38, 38, 0.5); }
  }

  .local-hero-visual {
    position: relative;
  }

  .local-visual-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
    border: 2px solid rgba(0, 229, 255, 0.15);
  }

  .local-hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .local-floating-tag {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: rgba(22, 32, 50, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0, 229, 255, 0.2);
    color: var(--white);
    padding: 10px 18px;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .local-floating-tag .pulse {
    width: 8px;
    height: 8px;
    background-color: var(--accent);
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
    animation: local-wa-pulse-ring 1.5s infinite;
  }

  @keyframes local-wa-pulse-ring {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  /* Local Article */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 50px;
  }

  .article-body h2 {
    font-size: 1.8rem;
    margin-bottom: 20px;
    text-transform: uppercase;
    color: var(--white);
  }

  .article-body h3 {
    font-size: 1.3rem;
    margin: 30px 0 15px;
    text-transform: uppercase;
    color: var(--white);
  }

  .article-body p {
    color: var(--gray-dark);
    margin-bottom: 20px;
    font-size: 1rem;
    line-height: 1.7;
  }

  .article-bullets {
    list-style: none;
    margin-bottom: 25px;
    padding-left: 5px;
  }

  .article-bullets li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--gray-dark);
    font-size: 0.95rem;
  }

  .article-bullets li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 800;
    font-size: 1.1rem;
  }

  .article-steps {
    margin-bottom: 25px;
    padding-left: 20px;
    color: var(--gray-dark);
  }

  .article-steps li {
    margin-bottom: 12px;
    padding-left: 5px;
    font-size: 0.95rem;
  }

  .article-steps strong {
    color: var(--white);
  }

  blockquote {
    border-left: 4px solid var(--accent);
    background-color: rgba(0, 229, 255, 0.05);
    padding: 20px 25px;
    margin: 30px 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--white);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  blockquote em {
    font-style: normal;
    font-weight: 700;
    color: var(--accent);
  }

  /* Sidebar */
  .sidebar-box {
    background-color: rgba(22, 32, 50, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 30px;
    border-radius: var(--radius-md);
    margin-bottom: 25px;
    box-shadow: var(--shadow-sm);
  }

  .contact-box {
    background: linear-gradient(135deg, #101c33 0%, #05080f 100%);
    border: 1px solid rgba(0, 229, 255, 0.15);
    color: var(--white);
    text-align: center;
  }

  .contact-box h3 {
    color: var(--white);
    margin-bottom: 12px;
    font-size: 1.3rem;
    text-transform: uppercase;
  }

  .contact-box p {
    color: #cbd5e1;
    font-size: 0.85rem;
    margin-bottom: 25px;
  }

  .sidebar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    font-weight: 700;
    border-radius: var(--radius-sm);
    margin-bottom: 12px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
  }

  .sidebar-btn:last-of-type {
    margin-bottom: 20px;
  }

  .sidebar-aux-phone {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .sidebar-aux-phone strong {
    color: var(--white);
  }

  .info-box h3 {
    font-size: 1.15rem;
    margin-bottom: 18px;
    text-transform: uppercase;
    border-bottom: 2px solid rgba(0, 229, 255, 0.15);
    padding-bottom: 8px;
    color: var(--white);
  }

  .info-box ul {
    list-style: none;
  }

  .info-box ul li {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    margin-bottom: 12px;
    color: #cbd5e1;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
    padding-bottom: 6px;
  }

  .info-box ul li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .info-box ul li strong {
    color: var(--white);
  }

  /* Fleet Grid */
  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
  }

  .fleet-card {
    background-color: rgba(22, 32, 50, 0.35);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .fleet-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .fleet-info {
    padding: 20px;
  }

  .fleet-info h4 {
    font-size: 1.1rem;
    margin-bottom: 6px;
    text-transform: uppercase;
    color: var(--white);
  }

  .fleet-info p {
    font-size: 0.85rem;
    color: var(--gray-dark);
    line-height: 1.5;
  }

  /* Other Bairros */
  .other-bairros {
    background-color: #090d16;
  }

  .other-bairros-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    max-width: 900px;
    margin: 0 auto 35px;
  }

  .other-bairro-link {
    background-color: rgba(22, 32, 50, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e2e8f0;
    transition: all 0.2s ease;
  }

  .other-bairro-link:hover {
    background-color: var(--accent);
    color: var(--primary-dark);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .view-all-bairros-wrapper {
    text-align: center;
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .local-hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .local-badge, .local-lead {
      margin-left: auto;
      margin-right: auto;
    }
    .local-hero-ctas {
      justify-content: center;
    }
    .local-hero-visual {
      max-width: 500px;
      margin: 0 auto;
    }
    .article-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .article-sidebar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .sidebar-box {
      margin-bottom: 0;
      height: 100%;
    }
    .fleet-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .local-hero-text h1 {
      font-size: 2.2rem;
    }
    .article-sidebar {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .local-hero-ctas .btn {
      width: 100%;
    }
  }
</style>
