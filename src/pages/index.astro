  <!-- Interactive Accordion Script -->
  <script>
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      
      if (question) {
        question.addEventListener('click', () => {
          const expanded = question.getAttribute('aria-expanded') === 'true';
          
          // Fechar todas as outras perguntas
          faqItems.forEach(otherItem => {
            if (otherItem !== item) {
              const otherBtn = otherItem.querySelector('.faq-question');
              const otherAnswer = otherItem.querySelector('.faq-answer');
              if (otherBtn && otherAnswer) {
                otherBtn.setAttribute('aria-expanded', 'false');
                (otherAnswer as HTMLElement).style.maxHeight = '0px';
              }
            }
          });
          
          // Abrir/Fechar a atual
          question.setAttribute('aria-expanded', String(!expanded));
          const answer = item.querySelector('.faq-answer');
          if (answer) {
            if (!expanded) {
              (answer as HTMLElement).style.maxHeight = (answer as HTMLElement).scrollHeight + 'px';
            } else {
              (answer as HTMLElement).style.maxHeight = '0px';
            }
          }
        });
      }
    });

    // Tabs Interativas para Bairros
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetTab = btn.getAttribute('data-tab');
        
        // Remover active das abas
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Esconder todos os painéis e exibir o selecionado
        tabPanels.forEach(panel => {
          if (panel.id === targetTab) {
            panel.classList.add('active');
          } else {
            panel.classList.remove('active');
          }
        });
      });
    });
  </script>
