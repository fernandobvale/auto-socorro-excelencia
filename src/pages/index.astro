---
import Layout from '../layouts/Layout.astro';
import { bairros } from '../data/bairros.js';
import { Image } from 'astro:assets';
import bannerImg from '../assets/images/banner.webp';
import serviceCarImg from '../assets/images/service_car.webp';
import servicePickupImg from '../assets/images/service_pickup.webp';
import serviceMotoImg from '../assets/images/service_moto.webp';
import serviceKombiImg from '../assets/images/service_kombi.webp';


// SEO Title e Description otimizados para Goiânia
const pageTitle = "Auto Socorro Excelência - Guincho 24 Horas em Goiânia e Aparecida";
const pageDescription = "Precisa de guincho em Goiânia ou Aparecida de Goiânia? O Auto Socorro Excelência oferece reboque rápido plataforma 24h para carros, motos e caminhonetes leves. Ligue agora!";

// FAQ Schema.org Structured Data
const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qual o tempo médio de chegada do guincho?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nosso tempo médio de chegada em Goiânia e Aparecida de Goiânia é de 20 a 40 minutos, dependendo do trânsito e da localização exata do veículo. Como estamos estrategicamente baseados no Setor Urias Magalhães, conseguimos um deslocamento muito rápido."
      }
    },
    {
      "@type": "Question",
      "name": "Quais tipos de veículos o Auto Socorro Excelência atende?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Atendemos carros de passeio de todos os modelos, motocicletas de baixa e alta cilindrada, picapes e caminhonetes leves (como S10, Hilux, Ranger) e utilitários leves. Nosso guincho plataforma hidráulico é moderno e preparado para transporte seguro."
      }
    },
    {
      "@type": "Question",
      "name": "Qual o valor do serviço de guincho em Goiânia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O valor do guincho varia de acordo com a distância a ser percorrida (quilometragem) e o tipo de veículo. Oferecemos o melhor custo-benefício de Goiânia, com preços justos e sem taxas ocultas. Entre em contato pelo WhatsApp para um orçamento imediato e sem compromisso."
      }
    },
    {
      "@type": "Question",
      "name": "O Auto Socorro Excelência funciona nos fins de semana e feriados?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim! Funcionamos 24 horas por dia, 7 dias por semana, incluindo domingos, feriados e madrugadas. Se precisar de auto socorro a qualquer hora, nossa equipe estará de prontidão para te atender."
      }
    },
    {
      "@type": "Question",
      "name": "Quais são as formas de pagamento aceitas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para sua total comodidade no momento da emergência, aceitamos pagamentos via PIX, cartões de crédito e débito, além de dinheiro em espécie."
      }
    }
  ]
});
---

<Layout title={pageTitle} description={pageDescription} schema={faqSchema}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-text-content">
        <span class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="emerg-icon"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          Serviço de Guincho Rápido 24 Horas
        </span>
        <h1>Auto Socorro Excelência: Guincho 24h em Goiânia e Região</h1>
        <p class="hero-lead">
          Seu carro quebrou, sofreu um sinistro ou precisa ser transportado? Nós resolvemos com agilidade! Oferecemos <strong>guincho plataforma 24 horas</strong> para carros, motos e caminhonetes leves, <strong>atendendo com rapidez 100% de Goiânia, Aparecida de Goiânia e toda a região metropolitana!</strong>
        </p>
        
        <div class="hero-cta-buttons">
          <a href="tel:+5562985869296" class="btn btn-tel pulsate-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            LIGAR: (62) 98586-9296
          </a>
          <a href="https://api.whatsapp.com/send?phone=5562985869296" target="_blank" rel="noopener noreferrer" class="btn btn-wa">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            CHAMAR NO WHATSAPP
          </a>
        </div>
        
        <div class="hero-features-list">
          <div class="hero-feature-item">
            <span class="check-icon">✓</span> Plataforma Hidráulica
          </div>
          <div class="hero-feature-item">
            <span class="check-icon">✓</span> Chegada em até 30 min
          </div>
          <div class="hero-feature-item">
            <span class="check-icon">✓</span> Menor Preço da Região
          </div>
        </div>
      </div>
      
      <div class="hero-visual">
        <div class="hero-card-image">
          <Image src={bannerImg} alt="Auto Socorro Excelência Guincho 24h em Goiânia" class="hero-main-img" width={576} height={324} loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Diferenciais / Confiança -->
  <section class="trust-section" id="diferenciais">
    <div class="container">
      <div class="section-header">
        <h2>Por Que Escolher o Auto Socorro Excelência?</h2>
        <p>Prestamos um serviço ágil e profissional para que você tenha a melhor experiência mesmo em momentos difíceis.</p>
      </div>
      
      <div class="trust-grid">
        <div class="trust-card">
          <div class="trust-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3>Disponibilidade 24H</h3>
          <p>Pane seca, mecânica ou colisão no meio da noite? Nosso guincho está de plantão 24h, de domingo a domingo, incluindo feriados.</p>
        </div>
        
        <div class="trust-card">
          <div class="trust-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
          </div>
          <h3>Rapidez Excepcional</h3>
          <p>Como conhecemos Goiânia como a palma de nossa mão e temos base própria, conseguimos chegar ao local do chamado em tempo recorde.</p>
        </div>
        
        <div class="trust-card">
          <div class="trust-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <h3>Segurança Garantida</h3>
          <p>Equipamentos modernos com plataforma hidráulica e amarrações homologadas que garantem que seu carro ou picape chegue intacto ao destino.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nossos Serviços -->
  <section class="services-section" id="servicos">
    <div class="container">
      <div class="section-header">
        <h2>Serviços de Auto Socorro Especializados</h2>
        <p>Dispomos de guincho ideal para transportes leves e médios com o cuidado que seu patrimônio merece.</p>
      </div>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-img-wrapper">
            <Image src={serviceCarImg} alt="Guincho de carros de passeio Goiânia" class="service-img" width={400} height={250} loading="lazy" />
            <span class="service-price-tag">Custo-Benefício</span>
          </div>
          <div class="service-content">
            <h3>Guincho para Carros</h3>
            <p>
              Reboque especializado para carros de passeio de todos os portes: hatches, sedans, SUVs e esportivos. Transporte seguro em plataforma hidráulica de última geração.
            </p>
            <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Preciso%20de%20um%20guincho%20para%20carro." class="service-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="service-wa-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              Solicitar Reboque via WhatsApp
            </a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-img-wrapper">
            <Image src={servicePickupImg} alt="Guincho de caminhonetes e picapes Goiânia" class="service-img" width={400} height={250} loading="lazy" />
            <span class="service-price-tag">Carga Leve/Média</span>
          </div>
          <div class="service-content">
            <h3>Guincho de Caminhonetes Leves</h3>
            <p>
              Plataforma robusta ideal para o transporte de caminhonetes e picapes leves (como S10, Hilux, Ranger, Toro, Oroch, Saveiro e Montana) com amarrações reforçadas de segurança.
            </p>
            <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Preciso%20de%20um%20guincho%20para%20caminhonete." class="service-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="service-wa-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              Solicitar Reboque via WhatsApp
            </a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-img-wrapper">
            <Image src={serviceMotoImg} alt="Guincho para motocicletas Goiânia" class="service-img" width={400} height={250} loading="lazy" />
            <span class="service-price-tag">Cuidado Total</span>
          </div>
          <div class="service-content">
            <h3>Guincho para Motos</h3>
            <p>
              Transporte cuidadoso de motos de baixa e alta cilindrada. Possuímos fixação adequada para que sua motocicleta viaje na vertical de forma totalmente estável e segura.
            </p>
            <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Preciso%20de%20um%20guincho%20para%20moto." class="service-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="service-wa-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              Solicitar Reboque via WhatsApp
            </a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-img-wrapper">
            <Image src={serviceKombiImg} alt="Socorro para veículos e projetos especiais" class="service-img" width={400} height={250} loading="lazy" />
            <span class="service-price-tag">Projetos Especiais</span>
          </div>
          <div class="service-content">
            <h3>Veículos Especiais e Utilitários</h3>
            <p>
              Fazemos o reboque de kombis, minivans, food trucks e projetos customizados com segurança e capricho, garantindo a integridade em trajetos curtos ou longos.
            </p>
            <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Preciso%20de%20um%20guincho%20para%20veículo%20especial." class="service-link" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="service-wa-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              Solicitar Reboque via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quem Somos / Base Física -->
  <section class="about-section" id="sobre">
    <div class="container about-grid">
      <div class="about-visual">
        <div class="about-location-card">
          <div class="map-mockup">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="map-pin-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <h4>Residencial Morumbi</h4>
            <p>Av. Marechal Rondon, Qd. C, Lt. 20 – Goiânia</p>
          </div>
          <div class="location-details">
            <p><strong>Nossa Base Estratégica:</strong> Estar sediado no Residencial Morumbi nos coloca próximos às saídas para a rodovia e com acesso direto a avenidas expressas, facilitando a chegada rápida em qualquer setor das regiões Norte, Sul, Leste e Oeste de Goiânia.</p>
          </div>
        </div>
      </div>
      
      <div class="about-text-content">
        <h2>Mais de Uma Década de Tradição em Reboque 24h</h2>
        <p>
          O <strong>Auto Socorro Excelência</strong> nasceu com a missão de oferecer um socorro na estrada que preza pela integridade do veículo e a tranquilidade do motorista. Entendemos que passar por um imprevisto com o carro é estressante, e por isso nossa postura é de total apoio, respeito e eficiência.
        </p>
        <p>
          Trabalhamos exclusivamente com motoristas habilitados, equipamentos modernos e revisados periodicamente. Sejam carros importados de luxo, picapes de trabalho ou motocicletas, nós garantimos um serviço sem complicações.
        </p>
        
        <div class="about-stats">
          <div class="stat-item">
            <span class="stat-num">24h</span>
            <span class="stat-label">De Plantão Todos os Dias</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">100%</span>
            <span class="stat-label">Frota Própria e Segura</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Local: Bairros Atendidos (O Segredo do SEO) -->
  <section class="bairros-section" id="bairros">
    <div class="container">
      <div class="section-header">
        <h2>Atendimento Rápido nos Principais Setores</h2>
        <p>Clique no seu bairro ou setor para ver informações detalhadas sobre o nosso tempo de chegada e solicitar o guincho plataforma mais próximo de você.</p>
      </div>

      <div class="tabs-container">
        <div class="tabs-header">
          <button class="tab-btn active" data-tab="goiania">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Goiânia - GO
          </button>
          <button class="tab-btn" data-tab="aparecida">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Aparecida de Goiânia - GO
          </button>
        </div>
        
        <div class="tabs-content">
          <div class="tab-panel active" id="goiania">
            <div class="bairros-grid">
              {bairros.filter(b => b.city === 'Goiânia').map(b => (
                <a href={`/guincho-em-${b.slug}`} class="bairro-card">
                  <span class="bairro-name">{b.name}</span>
                  <span class="bairro-time">⚡ Chegada Rápida</span>
                </a>
              ))}
            </div>
          </div>
          
          <div class="tab-panel" id="aparecida">
            <div class="bairros-grid">
              {bairros.filter(b => b.city === 'Aparecida de Goiânia').map(b => (
                <a href={`/guincho-em-${b.slug}`} class="bairro-card bairro-card-ap">
                  <span class="bairro-name">{b.name}</span>
                  <span class="bairro-time">⚡ Chegada Rápida</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Metropolitana Coverage Warning Banner -->
      <div class="coverage-highlight-banner">
        <div class="coverage-icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="coverage-icon"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
        <div class="coverage-content">
          <h4>🚨 ATENÇÃO: Atendemos 100% de Goiânia, Aparecida e Região Metropolitana!</h4>
          <p>Se o seu bairro ou setor não estiver listado na grade de principais setores acima, não se preocupe! <strong>Nossa frota de guinchos plataforma cobre absolutamente todas as regiões de Goiânia, Aparecida de Goiânia e municípios vizinhos da região metropolitana.</strong> Ligue ou nos envie sua localização no WhatsApp que enviaremos o auto socorro imediatamente!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dúvidas Frequentes (FAQ) -->
  <section class="faq-section" id="faq">
    <div class="container">
      <div class="section-header">
        <h2>Dúvidas Frequentes sobre Reboque e Guincho</h2>
        <p>Separamos as principais perguntas de nossos clientes para ajudar você a entender melhor como funciona a contratação do auto socorro.</p>
      </div>
      
      <div class="faq-accordion-container">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span>Qual o tempo médio de chegada do guincho?</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>Nosso tempo médio de chegada em Goiânia e Aparecida de Goiânia é de 20 a 40 minutos, dependendo do trânsito e da localização exata do veículo. Como estamos estrategicamente baseados no Setor Urias Magalhães, conseguimos um deslocamento muito rápido para qualquer região.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span>Quais tipos de veículos o Auto Socorro Excelência atende?</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <p>Atendemos carros de passeio de todos os modelos, motocicletas de baixa e alta cilindrada, picapes e caminhonetes leves (como S10, Hilux, Ranger, Toro) e utilitários leves. Nosso guincho plataforma hidráulico é moderno e preparado para transporte seguro. Não atendemos caminhões pesados.</p>
          </div>
        </div>

        <div class="faq-item">
