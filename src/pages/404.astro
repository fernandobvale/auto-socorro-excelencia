---
import Layout from '../layouts/Layout.astro';

// SEO Title and Description for 404 page
const pageTitle = "Página Não Encontrada | Auto Socorro Excelência";
const pageDescription = "A página que você procura não foi encontrada. Volte para a página inicial do Auto Socorro Excelência e solicite seu guincho 24 horas.";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="not-found-section">
    <div class="container not-found-content">
      <div class="error-code">404</div>
      <h1>Ops! Página não encontrada</h1>
      <p class="error-message">
        A página que você tentou acessar não existe, foi movida ou o link está incorreto.
        Mas não se preocupe, nosso serviço de guincho e auto socorro continua operando normalmente 24 horas por dia!
      </p>
      
      <div class="cta-actions">
        <a href="/" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          VOLTAR PARA O INÍCIO
        </a>
        <a href="https://api.whatsapp.com/send?phone=5562985869296&text=Olá!%20Não%20encontrei%20o%20que%20queria%20no%20site,%20mas%20preciso%20de%20um%20guincho." target="_blank" rel="noopener noreferrer" class="btn btn-wa">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          CHAMAR NO WHATSAPP
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found-section {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 0;
    background-color: var(--dark); /* dark mode base for excelencia */
  }

  .not-found-content {
    max-width: 600px;
  }

  .error-code {
    font-family: var(--font-heading);
    font-size: 8rem;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
    margin-bottom: 20px;
    text-shadow: 0 10px 30px rgba(255, 202, 0, 0.2);
  }

  h1 {
    font-size: 2.2rem;
    color: var(--white);
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .error-message {
    font-size: 1.1rem;
    color: var(--gray-dark);
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  @media (max-width: 600px) {
    .error-code {
      font-size: 6rem;
    }
    h1 {
      font-size: 1.8rem;
    }
    .cta-actions {
      flex-direction: column;
    }
  }
</style>
